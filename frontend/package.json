{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:unsafe": "biome check --write --unsafe",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "hook:install": "lefthook install",
    "hook:pre-commit": "lefthook run pre-commit",
    "create:tool": "node scripts/create-tool.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "babel-plugin-react-compiler": "1.0.0",
    "lefthook": "^2.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.12"
    }
  }
}
